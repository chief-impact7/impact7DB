{
  "firestore": {
    "database": "(default)",
    "location": "asia-northeast3",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "_redirect",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "redirects": [
      { "source": "**", "destination": "https://impact7-app.web.app/db", "type": 301 }
    ]
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "leave-request",
      "runtime": "nodejs22",
      "ignore": ["node_modules", ".git", "*.log"]
    },
    {
      "source": "functions-shared",
      "codebase": "shared",
      "runtime": "nodejs22",
      "ignore": ["node_modules", ".git", "*.log"]
    }
  ]
}
