{
  "name": "impact7-functions",
  "engines": {
    "node": "22"
  },
  "main": "index.js",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run --exclude '**/*.integration.test.js'",
    "test:integration": "firebase emulators:exec --only firestore --project demo-impact7 \"vitest run integration\"",
    "test:watch": "vitest",
    "serve": "firebase emulators:start --only functions,firestore",
    "deploy": "firebase deploy --only functions:leave-request --project impact7db",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "@impact7/shared": "github:chief-impact7/impact7-shared#v1.41.0",
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^7.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "firebase-functions-test": "^3.3.0",
    "vitest": "^2.0.0"
  },
  "private": true
}
