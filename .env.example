# Firebase 환경변수 — .env 파일로 복사 후 사용
# cp .env.example .env

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Google Identity Services (GIS) 토큰 자동 갱신용 OAuth Web Client ID
# Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
# > "Web client (auto created by Google Service)" 의 client_id 복사
VITE_GOOGLE_CLIENT_ID=your-web-oauth-client-id.apps.googleusercontent.com
